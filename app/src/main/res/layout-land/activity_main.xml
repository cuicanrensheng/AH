<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ==================================================================== -->
    <!-- ✅ 主播放器（加上 keep_content_on_player_reset，暂停时保持最后一帧） -->
    <!-- ==================================================================== -->
    <com.google.android.exoplayer2.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        app:use_controller="false"
        app:resize_mode="fit"
        app:keep_content_on_player_reset="true"
        app:surface_type="surface_view" />

    <!-- ==================================================================== -->
    <!-- ✅ 防花屏占位图（退到后台时显示，黑色背景盖住 SurfaceView）        -->
    <!-- ==================================================================== -->
    <ImageView
        android:id="@+id/iv_player_placeholder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:scaleType="centerCrop"
        android:background="@android:color/black" />

    <TextView
        android:id="@+id/tv_channel_num"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:text="1"
        android:textSize="50sp"
        android:textColor="#FFF"
        android:alpha="0.8"
        android:visibility="gone" />

    <!-- ==================================================================== -->
    <!-- ✅ 频道面板容器（两个完整面板切换显示）                              -->
    <!--                                                                    -->
    <!-- 【结构说明】                                                       -->
    <!-- 两个面板在 FrameLayout 中切换显示：                                 -->
    <!--   1. 左侧面板（默认）：分组 + 频道列表 + 节目单按钮                 -->
    <!--   2. 右侧面板（展开）：返回按钮 + 频道列表 + 日期 + EPG             -->
    <!-- ==================================================================== -->
    <FrameLayout
        android:id="@+id/panel_layout"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- ================================================================ -->
        <!-- ✅ 左侧面板：分组 + 频道列表 + 节目单按钮（默认显示）            -->
        <!-- ================================================================ -->
        <LinearLayout
            android:id="@+id/ll_left_panel"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:background="@drawable/panel_bg">

            <!-- 分组列表 -->
            <ListView
                android:id="@+id/lv_group"
                android:layout_width="130dp"
                android:layout_height="match_parent"
                android:background="@android:color/transparent" />

            <!-- 频道列表 -->
            <ListView
                android:id="@+id/lv_channel_list"
                android:layout_width="200dp"
                android:layout_height="match_parent"
                android:background="@android:color/transparent" />

            <!-- 节目单按钮（在最右边） -->
            <TextView
                android:id="@+id/btn_show_epg"
                android:layout_width="50dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="节\n目\n单"
                android:textColor="#ffffff"
                android:textSize="14sp"
                android:focusable="true"
                android:clickable="true" />
        </LinearLayout>

        <!-- ================================================================ -->
        <!-- ✅ 右侧面板：返回 + 频道列表 + 日期 + EPG（默认隐藏）            -->
        <!-- ================================================================ -->
        <LinearLayout
            android:id="@+id/ll_right_panel"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:background="@drawable/panel_bg"
            android:visibility="gone">

            <!-- 返回按钮（在最左边，显示"频道组"） -->
            <TextView
                android:id="@+id/btn_back_group"
                android:layout_width="50dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="频\n道\n组"
                android:textColor="#ffffff"
                android:textSize="14sp"
                android:focusable="true"
                android:clickable="true" />

            <!-- 频道列表（节目单页面的频道列表） -->
            <ListView
                android:id="@+id/lv_channel_list_epg"
                android:layout_width="200dp"
                android:layout_height="match_parent"
                android:background="@android:color/transparent" />

            <!-- 日期列表 -->
            <ListView
                android:id="@+id/lv_date"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:background="@android:color/transparent" />

            <!-- EPG节目列表 -->
            <ListView
                android:id="@+id/lv_epg"
                android:layout_width="360dp"
                android:layout_height="match_parent"
                android:background="@android:color/transparent" />
        </LinearLayout>
    </FrameLayout>

    <!-- 底部信息栏 原样保留 -->
    <LinearLayout
        android:id="@+id/info_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_channel_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_tag_fhd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:background="#DDDDDD"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:textSize="12sp"
                android:textColor="#000" />

            <TextView
                android:id="@+id/tv_tag_audio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="6dp"
                android:background="#DDDDDD"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:textSize="12sp"
                android:textColor="#000" />

            <TextView
                android:id="@+id/tv_bitrate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tv_current_time_range"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <ProgressBar
                android:id="@+id/progress_program"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="3dp"
                android:layout_marginHorizontal="8dp" />

            <TextView
                android:id="@+id/tv_remaining_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_current_program_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tv_next_time_range"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_next_program_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
