<?xml version="1.0" encoding="utf-8"?>
<!--
  设置页面布局（右侧滑出式菜单风格）
  【作用】设置页面的整体布局
  【效果】屏幕右侧显示，四个角圆角，半透明深色背景
  【结构】FrameLayout（全屏透明） → ScrollView（右侧内容） → LinearLayout（设置项）

  【2026-06-19 修改：改成四个角圆角 + 右侧滑出菜单样式】
  1. 根布局改成 FrameLayout，背景透明
  2. 内容区域靠右对齐，固定宽度 240dp
  3. 离右边 20dp 距离，让右侧圆角能看到
  4. 上下各 20dp 边距
  5. 背景：settings_panel_bg（四个角圆角，半透明深色）
  6. 和频道面板风格完全统一，一个在左一个在右，对称
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">
    <!--
      ✅ 根布局改成 FrameLayout + 透明背景
      【为什么？】
      因为设置面板是从右侧滑出来的，左边能看到播放画面，
      所以根布局必须是透明的。
    -->

    <!-- ================================================================ -->
    <!-- 设置面板：靠右显示，离右边有 20dp 距离，四个角圆角半透明背景  -->
    <!-- ================================================================ -->
    <!--
      ✅ 关键修改点
      1. 宽度：固定 240dp（窄菜单风格）
      2. 高度：match_parent（撑满大部分屏幕高度）
      3. 对齐：layout_gravity="end"（靠右对齐）
      4. 右边距：layout_marginEnd="20dp"（离右边 20dp，让右侧圆角能看到）
      5. 上下边距：layout_marginTop/Bottom="20dp"（上下各 20dp）
      6. 背景：settings_panel_bg（四个角圆角，半透明深色）
      7. 内边距：上下 20dp，左右 16dp

      【和频道面板的对称关系】
      ┌─────────────────────────────────────────────┐
      │                                             │
      │  ╭─────────╮                  ╭─────────╮  │
      │  │ 频道面板 │   播放画面        │ 设置面板 │  │
      │  │ ...      │                  │ ...     │  │
      │  ╰─────────╯                  ╰─────────╯  │
      │   ↑ 20dp                        ↑ 20dp     │
      │   左边距                          右边距    │
      │                                             │
      └─────────────────────────────────────────────┘

      两个面板完全对称：
      - 圆角大小：一样（20dp）
      - 背景颜色：一样（#B30A0A1A，深蓝黑色半透明）
      - 上下边距：一样（20dp）
      - 离边距离：一样（20dp）
      - 宽度：不一样（频道面板宽，设置面板窄）
      - 位置：不一样（一个左，一个右）
    -->
    <ScrollView
        android:id="@+id/settings_content"
        android:layout_width="240dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/settings_panel_bg"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ============================================================ -->
            <!-- 开机自启（两行布局：文字+开关 + 状态文本） -->
            <!-- ============================================================ -->
            <LinearLayout
                android:id="@+id/item_boot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:background="@drawable/setting_item_bg"
                android:focusable="true"
                android:clickable="true">

                <!-- 第一行：文字 + 开关 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="开机自启"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <Switch
                        android:id="@+id/sw_boot"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:clickable="false" />

                </LinearLayout>

                <!-- 第二行：状态文本 -->
                <TextView
                    android:id="@+id/tv_boot_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="未开启"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- ============================================================ -->
            <!-- 节目单开关 -->
            <!-- ============================================================ -->
            <LinearLayout
                android:id="@+id/item_epg"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:background="@drawable/setting_item_bg"
                android:focusable="true"
                android:clickable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="节目单开关"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <Switch
                    android:id="@+id/sw_epg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="false" />

            </LinearLayout>

            <!-- ============================================================ -->
            <!-- 自动更新源 -->
            <!-- ============================================================ -->
            <LinearLayout
                android:id="@+id/item_auto_update"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:background="@drawable/setting_item_bg"
                android:focusable="true"
                android:clickable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="自动更新源"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <Switch
                    android:id="@+id/sw_auto_update"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="false" />

            </LinearLayout>

            <!-- ============================================================ -->
            <!-- 换台反转 -->
            <!-- ============================================================ -->
            <LinearLayout
                android:id="@+id/item_reverse"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:background="@drawable/setting_item_bg"
                android:focusable="true"
                android:clickable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="换台反转"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <Switch
                    android:id="@+id/sw_reverse"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="false" />

            </LinearLayout>

            <!-- ============================================================ -->
            <!-- 数字选台 -->
            <!-- ============================================================ -->
            <LinearLayout
                android:id="@+id/item_num_channel"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:background="@drawable/setting_item_bg"
                android:focusable="true"
                android:clickable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="数字选台"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <Switch
                    android:id="@+id/sw_num_channel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="false" />

            </LinearLayout>

            <!-- ============================================================ -->
            <!-- 分隔线 -->
            <!-- ============================================================ -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <!-- ============================================================ -->
            <!-- 屏幕比例 -->
            <!-- ============================================================ -->
            <TextView
                android:id="@+id/tv_screen_ratio"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="屏幕比例"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/setting_item_bg"
                android:focusable="true"
                android:clickable="true" />

            <!-- ============================================================ -->
            <!-- 自定义订阅源 -->
            <!-- ============================================================ -->
            <TextView
                android:id="@+id/tv_custom_source"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="自定义订阅源"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/setting_item_bg"
                android:focusable="true"
                android:clickable="true" />

            <!-- ============================================================ -->
            <!-- 自定义节目单 -->
            <!-- ============================================================ -->
            <TextView
                android:id="@+id/tv_custom_epg"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="自定义节目单"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/setting_item_bg"
                android:focusable="true"
                android:clickable="true" />

            <!-- ============================================================ -->
            <!-- 多订阅源 -->
            <!-- ============================================================ -->
            <TextView
                android:id="@+id/tv_multi_source"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="多订阅源"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/setting_item_bg"
                android:focusable="true"
                android:clickable="true" />

            <!-- ============================================================ -->
            <!-- 多节目单 -->
            <!-- ============================================================ -->
            <TextView
                android:id="@+id/tv_multi_epg"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="多节目单"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/setting_item_bg"
                android:focusable="true"
                android:clickable="true" />

            <!-- ============================================================ -->
            <!-- 扫码添加 -->
            <!-- ============================================================ -->
            <TextView
                android:id="@+id/tv_qr_code"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="扫码添加直播源/节目单"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/setting_item_bg"
                android:focusable="true"
                android:clickable="true" />

            <!-- ============================================================ -->
            <!-- 分隔线 -->
            <!-- ============================================================ -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <!-- ============================================================ -->
            <!-- 查看解析日志 -->
            <!-- ============================================================ -->
            <TextView
                android:id="@+id/log_viewer"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="📄 查看解析日志"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/setting_item_bg"
                android:focusable="true"
                android:clickable="true" />

            <!-- ============================================================ -->
            <!-- 操作崩溃日志 -->
            <!-- ============================================================ -->
            <TextView
                android:id="@+id/log_operation"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="📌 操作崩溃日志"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/setting_item_bg"
                android:focusable="true"
                android:clickable="true" />

            <!-- ============================================================ -->
            <!-- 检查更新 -->
            <!-- ============================================================ -->
            <LinearLayout
                android:id="@+id/item_check_update"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:background="@drawable/setting_item_bg"
                android:focusable="true"
                android:clickable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="检查更新"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/btn_check_update"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="检查更新"
                    android:focusable="false"
                    android:clickable="false" />

            </LinearLayout>

            <!-- ============================================================ -->
            <!-- 网页设置提示 -->
            <!-- ============================================================ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="网页设置：http://设备IP:10481"
                android:textColor="#80FFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

    </ScrollView>

</FrameLayout>
