<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">
    <!-- 底层播放器 -->
    <com.google.android.exoplayer2.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        app:use_controller="false"
        app:resize_mode="fit"/>

    <!-- 右上角切台数字弹窗 -->
    <TextView
        android:id="@+id/tv_channel_num"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:text="1"
        android:textSize="50sp"
        android:textColor="#FFF"
        android:alpha="0.8"
        android:visibility="gone"/>

    <!-- 侧边控制面板总布局 -->
    <LinearLayout
        android:id="@+id/panel_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:visibility="gone">
        <!-- 左侧分组列表 -->
        <ListView
            android:id="@+id/lv_group"
            android:layout_width="130dp"
            android:layout_height="match_parent"
            android:background="#CC000000"
            android:listSelector="@drawable/list_item_bg"
            android:choiceMode="singleChoice"
            android:drawSelectorOnTop="false"/>
        <!-- 中间频道列表 -->
        <ListView
            android:id="@+id/lv_channel_list"
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:background="#CC000000"
            android:listSelector="@drawable/list_item_bg"
            android:choiceMode="singleChoice"
            android:drawSelectorOnTop="false"/>
        <!-- 竖向节目单按钮（居中竖排文字，原id btn_show_epg不变） -->
        <TextView
            android:id="@+id/btn_show_epg"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:background="#99000000"
            android:gravity="center"
            android:text="节\n目\n单"
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:focusable="true"
            android:clickable="true"/>
        <!-- 日期列表 默认隐藏 -->
        <ListView
            android:id="@+id/lv_date"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:background="#CC000000"
            android:visibility="gone"
            android:listSelector="@drawable/list_item_bg"
            android:choiceMode="singleChoice"
            android:drawSelectorOnTop="false"/>
        <!-- EPG节目列表 默认隐藏 -->
        <ListView
            android:id="@+id/lv_epg"
            android:layout_width="360dp"
            android:layout_height="match_parent"
            android:background="#CC000000"
            android:visibility="gone"
            android:listSelector="@drawable/list_item_bg"
            android:choiceMode="singleChoice"
            android:drawSelectorOnTop="false"/>
    </LinearLayout>

    <!-- 底部信息栏 原样保留 -->
    <LinearLayout
        android:id="@+id/info_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/tv_channel_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tv_tag_fhd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:background="#DDDDDD"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:textSize="12sp"
                android:textColor="#000"/>
            <TextView
                android:id="@+id/tv_tag_audio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="6dp"
                android:background="#DDDDDD"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:textSize="12sp"
                android:textColor="#000"/>
            <TextView
                android:id="@+id/tv_bitrate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:textColor="#FFFFFF"
                android:textSize="14sp"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">
            <TextView
                android:id="@+id/tv_current_time_range"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="13sp"/>
            <ProgressBar
                android:id="@+id/progress_program"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="3dp"
                android:layout_marginHorizontal="8dp"/>
            <TextView
                android:id="@+id/tv_remaining_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="13sp"/>
            <TextView
                android:id="@+id/tv_current_program_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:textColor="#FFFFFF"
                android:textSize="13sp"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">
            <TextView
                android:id="@+id/tv_next_time_range"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="12sp"/>
            <TextView
                android:id="@+id/tv_next_program_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
