<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- 播放器 -->
    <com.google.android.exoplayer2.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"/>

    <!-- 点击弹出：频道分组 + 频道列表 + 日期 + 节目单 -->
    <LinearLayout
        android:id="@+id/panel_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:visibility="gone">

        <!-- 1 频道分组 -->
        <ListView
            android:id="@+id/lv_group"
            android:layout_width="130dp"
            android:layout_height="match_parent"
            android:background="#CC000000"
            android:textColor="#ffffff"/>

        <!-- 2 频道列表 -->
        <ListView
            android:id="@+id/lv_channel_list"
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:background="#CC000000"/>

        <!-- 3 节目单按钮 -->
        <TextView
            android:id="@+id/btn_show_epg"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:background="#99000000"
            android:gravity="center"
            android:text="节目单"
            android:textColor="#ffffff"
            android:textSize="14sp" />

        <!-- 4 日期 默认隐藏 -->
        <ListView
            android:id="@+id/lv_date"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:background="#CC000000"
            android:visibility="gone"/>

        <!-- 5 节目单 EPG 默认隐藏 -->
        <ListView
            android:id="@+id/lv_epg"
            android:layout_width="360dp"
            android:layout_height="match_parent"
            android:background="#CC000000"
            android:textColor="#ffffff"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- ====================== 【新增：信息栏 - 滑动显示 2秒隐藏】 ====================== -->
    <LinearLayout
        android:id="@+id/info_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#CC000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/tv_channel_name"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tv_tag_fhd"
                android:layout_marginLeft="16dp"
                android:background="#CCCCCC"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:textSize="20sp"/>
            <TextView
                android:id="@+id/tv_tag_audio"
                android:layout_marginLeft="12dp"
                android:background="#CCCCCC"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:textSize="20sp"/>
            <TextView
                android:id="@+id/tv_bitrate"
                android:layout_marginLeft="16dp"
                android:textColor="#FFFFFF"
                android:textSize="26sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">
            <TextView
                android:id="@+id/tv_current_time_range"
                android:textColor="#FFFFFF"
                android:textSize="26sp"/>
            <ProgressBar
                android:id="@+id/progress_program"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="6dp"
                android:layout_marginHorizontal="12dp"/>
            <TextView
                android:id="@+id/tv_remaining_time"
                android:textColor="#FFFFFF"
                android:textSize="26sp"/>
            <TextView
                android:id="@+id/tv_current_program_name"
                android:layout_marginLeft="16dp"
                android:textColor="#FFFFFF"
                android:textSize="26sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">
            <TextView
                android:id="@+id/tv_next_time_range"
                android:textColor="#AAAAAA"
                android:textSize="24sp"/>
            <TextView
                android:id="@+id/tv_next_program_name"
                android:layout_marginLeft="16dp"
                android:textColor="#AAAAAA"
                android:textSize="24sp"/>
        </LinearLayout>
    </LinearLayout>
    <!-- ====================== 【新增结束】 ====================== -->

</FrameLayout>
