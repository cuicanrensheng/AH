<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ==================================================================== -->
    <!-- 播放器视图（最底层） -->
    <!-- ==================================================================== -->
    <!--
        【属性说明】
        - app:use_controller="false"：屏蔽 ExoPlayer 原生的播放控制栏，我们自己做 UI
        - app:resize_mode="fit"：默认按比例适配，不拉伸不裁剪
    -->
    <com.google.android.exoplayer2.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        app:use_controller="false"
        app:resize_mode="fit" />

    <!-- ==================================================================== -->
    <!-- ✅ 右上角：频道号 + 日期 + 实时时间（打开面板时显示） -->
    <!-- ==================================================================== -->
    <!--
        【显示时机】
        - 默认隐藏（visibility="gone"）
        - 打开左侧频道面板时显示
        - 关闭面板时隐藏

        【布局结构】
        - 横向排列：频道号 | 分隔线 | 日期+时间（纵向）
        - 频道号大字体（48sp），日期时间小字体，层次分明
    -->
    <LinearLayout
        android:id="@+id/ll_top_right"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="30dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <!-- 频道号（大字体，加粗） -->
        <TextView
            android:id="@+id/tv_channel_num"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1"
            android:textSize="48sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginEnd="12dp" />

        <!-- 分隔线（半透明白色） -->
        <View
            android:layout_width="1dp"
            android:layout_height="36dp"
            android:background="#44FFFFFF" />

        <!-- 日期 + 时间（垂直排列，右对齐） -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:gravity="end">

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="06/19 周五"
                android:textSize="14sp"
                android:textColor="#CCFFFFFF" />

            <TextView
                android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="09:57:15"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ==================================================================== -->
    <!-- 左侧频道面板（三栏式：分组 → 频道 → 节目单按钮） -->
    <!-- ==================================================================== -->
    <!--
        【三栏布局说明】
        第一栏：频道分组列表（130dp 宽）
        第二栏：频道列表（200dp 宽）
        第三栏：节目单按钮（50dp 宽，竖排文字）
        点击节目单按钮后，右侧展开节目单区域（日期列表 + 节目列表）

        【显示时机】
        - 默认隐藏（visibility="gone"）
        - 按确认键/左右键/菜单键时显示
    -->
    <LinearLayout
        android:id="@+id/panel_layout"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:visibility="gone">

        <!-- 第一栏：频道分组 -->
        <ListView
            android:id="@+id/lv_group"
            android:layout_width="130dp"
            android:layout_height="match_parent"
            android:background="#CC000000"
            android:paddingVertical="20dp"
            android:divider="@null"
            android:listSelector="@android:color/transparent" />

        <!-- 第二栏：频道列表 -->
        <ListView
            android:id="@+id/lv_channel_list"
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:background="#CC000000"
            android:paddingVertical="20dp"
            android:divider="@null"
            android:listSelector="@android:color/transparent" />

        <!-- 第三栏：节目单按钮（竖排文字） -->
        <!--
            【为什么用竖排文字？】
            因为按钮很窄（50dp），横排放不下"节目单"三个字，
            用换行符 \n 实现竖排效果，节省横向空间。
        -->
        <TextView
            android:id="@+id/btn_show_epg"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:background="#99000000"
            android:gravity="center"
            android:text="节\n目\n单"
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:focusable="true"
            android:clickable="true" />

        <!-- 节目单区域（点击按钮后展开，默认隐藏） -->
        <LinearLayout
            android:id="@+id/ll_epg_panel"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:visibility="gone">

            <!-- 日期列表（窄列，60dp） -->
            <ListView
                android:id="@+id/lv_date"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:background="#CC000000"
                android:paddingVertical="20dp"
                android:divider="@null"
                android:listSelector="@android:color/transparent" />

            <!-- EPG 节目列表（宽列，360dp） -->
            <ListView
                android:id="@+id/lv_epg"
                android:layout_width="360dp"
                android:layout_height="match_parent"
                android:background="#CC000000"
                android:paddingVertical="10dp"
                android:divider="@null"
                android:listSelector="@android:color/transparent" />
        </LinearLayout>
    </LinearLayout>

    <!-- ==================================================================== -->
    <!-- 底部信息栏（切台时显示，5秒后自动隐藏） -->
    <!-- ==================================================================== -->
    <!--
        【显示时机】
        - 默认隐藏
        - 切换频道时显示
        - 5 秒后自动隐藏

        【三行布局】
        第一行：频道名称 + 画质标签 + 音频标签 + 码率
        第二行：节目时间 + 进度条 + 剩余时间 + 节目名称
        第三行：下一个节目预告
    -->
    <LinearLayout
        android:id="@+id/info_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:visibility="gone">

        <!-- 第一行：频道名称 + 画质标签 + 音频标签 + 码率 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_channel_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1" />

            <!-- 画质标签（半透明白色背景） -->
            <TextView
                android:id="@+id/tv_tag_fhd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="#33FFFFFF"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:textSize="12sp"
                android:textColor="#FFFFFF" />

            <!-- 音频标签 -->
            <TextView
                android:id="@+id/tv_tag_audio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="#33FFFFFF"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:textSize="12sp"
                android:textColor="#FFFFFF" />

            <!-- 码率（次要信息，浅灰色） -->
            <TextView
                android:id="@+id/tv_bitrate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:textColor="#99FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 第二行：当前节目时间 + 进度条 + 剩余时间 + 节目名 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tv_current_time_range"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#99FFFFFF"
                android:textSize="13sp" />

            <!-- 节目进度条（绿色进度，白色背景） -->
            <ProgressBar
                android:id="@+id/progress_program"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="3dp"
                android:layout_marginHorizontal="10dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#4CAF50"
                android:progressBackgroundTint="#33FFFFFF" />

            <TextView
                android:id="@+id/tv_remaining_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#66FFFFFF"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_current_program_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:ellipsize="end"
                android:maxLines="1" />
        </LinearLayout>

        <!-- 第三行：下一个节目预告 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="接下来："
                android:textColor="#666666"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_next_time_range"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#666666"
                android:textSize="12sp"
                android:layout_marginStart="4dp" />

            <TextView
                android:id="@+id/tv_next_program_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#999999"
                android:textSize="12sp"
                android:layout_marginStart="6dp"
                android:ellipsize="end"
                android:maxLines="1" />
        </LinearLayout>
    </LinearLayout>

    <!-- ==================================================================== -->
    <!-- ✅ 右下角信息栏（打开面板时显示，一直显示） -->
    <!-- ==================================================================== -->
    <!--
        【显示时机】
        - 默认隐藏
        - 打开左侧频道面板时显示
        - 关闭面板时隐藏
        - 面板打开期间一直显示，不会自动隐藏

        【和底部信息栏的区别】
        - 底部信息栏：切台时显示，5 秒后自动隐藏（全屏观看时不遮挡）
        - 右下角信息栏：打开面板时显示，一直显示（浏览频道时随时看节目信息）

        【背景】
        使用自定义 drawable：info_bar_corner_bg.xml（圆角 + 半透明黑色）
    -->
    <LinearLayout
        android:id="@+id/info_bar_corner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="32dp"
        android:layout_marginEnd="32dp"
        android:background="@drawable/info_bar_corner_bg"
        android:orientation="vertical"
        android:padding="14dp"
        android:visibility="gone">

        <!-- 第一行：频道名称 + 画质标签 + 音频标签 + 码率 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_channel_name_corner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="频道名称"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                android:maxEms="12"
                android:ellipsize="end"
                android:singleLine="true"/>

            <!-- 画质标签 -->
            <TextView
                android:id="@+id/tv_tag_fhd_corner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="#40FFFFFF"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="FHD"
                android:textColor="#FFFFFF"
                android:textSize="12sp"/>

            <!-- 音频标签 -->
            <TextView
                android:id="@+id/tv_tag_audio_corner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="#40FFFFFF"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="立体声"
                android:textColor="#FFFFFF"
                android:textSize="12sp"/>

            <!-- 码率 -->
            <TextView
                android:id="@+id/tv_bitrate_corner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="0KB/s"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- 第二行：当前节目时间 + 进度条 + 剩余时间 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_current_time_range_corner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00 - 23:59"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"/>

            <!-- 节目进度条 -->
            <ProgressBar
                android:id="@+id/progress_program_corner"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="3dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#4CAF50"
                android:progressBackgroundTint="#33FFFFFF"/>

            <TextView
                android:id="@+id/tv_remaining_time_corner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="剩余30分"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- 第三行：当前节目名称 -->
        <TextView
            android:id="@+id/tv_current_program_name_corner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="精彩节目"
            android:textColor="#E6FFFFFF"
            android:textSize="14sp"
            android:maxEms="18"
            android:ellipsize="end"
            android:singleLine="true"/>

        <!-- 第四行：下一个节目预告 -->
        <TextView
            android:id="@+id/tv_next_program_corner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="接下来：xxx"
            android:textColor="#66FFFFFF"
            android:textSize="12sp"
            android:maxEms="20"
            android:ellipsize="end"
            android:singleLine="true"/>
    </LinearLayout>

    <!-- ==================================================================== -->
    <!-- ✅ 新增：加载动画视图（居中显示，加载直播源时显示） -->
    <!-- ==================================================================== -->
    <!--
        【显示时机】
        - 默认隐藏
        - 启动应用加载直播源时显示
        - 加载完成或超时后隐藏
        - 15 秒超时保护（MainActivity 里控制）

        【为什么需要加载动画？】
        直播源加载需要时间（网络请求 + 解析），如果直接黑屏，
        用户会以为应用卡住了。加个加载动画，让用户知道正在加载。

        【布局结构】
        - 垂直排列：ProgressBar（转圈动画） + 文字提示
        - 居中显示，不挡其他内容
    -->
    <LinearLayout
        android:id="@+id/loading_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <!-- 加载转圈动画 -->
        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="#FFFFFF" />

        <!-- 加载文字提示 -->
        <TextView
            android:id="@+id/tv_loading_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="加载中..."
            android:textColor="#FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

</FrameLayout>
