<?xml version="1.0" encoding="utf-8"?>
<!--
  主页面布局
  【作用】直播应用的主页面，包含播放器、频道面板、信息栏等
  【结构】FrameLayout 帧布局，子 View 按顺序叠加显示
  【2026-06-19 修改：频道面板改成四个角圆角 + 半透明深色背景】
  - 面板离左边 20dp 距离，让左侧圆角能看到
  - 上下各 20dp 边距
  - 和设置面板风格统一，一个在左一个在右，对称

  【2026-06-20 修改：防花屏方案】
  1. 使用 TextureView 渲染（app:surface_type="texture_view"）
     - 切台时保持最后一帧，不会花屏
     - 和 UI 在同一层，没有 Surface 销毁的问题
  2. 保留占位图方案（退到后台时显示）
     - 退到后台时显示黑色占位图，盖住播放器
     - 防止 Surface 销毁过程中出现短暂花屏
     - 回到前台后延迟 100ms 隐藏，等 Surface 准备好
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ==================================================================== -->
    <!-- 主播放器视图（ExoPlayer 的 PlayerView）                              -->
    <!-- ==================================================================== -->
    <!--
      ✅ 已设置 texture_view，解决切台花屏问题
      - surface_type="texture_view"：使用 TextureView，不会有 Surface 销毁的花屏
      - keep_content_on_player_reset="true"：切台时保持最后一帧，避免黑屏
    -->
    <com.google.android.exoplayer2.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        app:use_controller="false"
        app:resize_mode="fit"
        app:keep_content_on_player_reset="true"
        app:surface_type="texture_view" />

    <!-- ==================================================================== -->
    <!-- 防花屏占位图（退到后台时显示，盖住播放器）                          -->
    <!-- ==================================================================== -->
    <!--
      【作用】退到后台时显示黑色背景，盖住播放器，防止 Surface 销毁时花屏
      【时机】onPause 时显示，onResume 后延迟 100ms 隐藏
      【默认状态】gone，正常播放时不显示
    -->
    <ImageView
        android:id="@+id/iv_player_placeholder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        android:visibility="gone" />

    <!-- ==================================================================== -->
    <!-- 频道号显示（右上角大数字，切台时显示）                              -->
    <!-- ==================================================================== -->
    <TextView
        android:id="@+id/tv_channel_num"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:text="1"
        android:textSize="50sp"
        android:textColor="#FFF"
        android:alpha="0.8"
        android:visibility="gone" />

    <!-- ==================================================================== -->
    <!-- 频道面板容器（两个完整面板切换显示）                                -->
    <!-- ==================================================================== -->
    <FrameLayout
        android:id="@+id/panel_layout"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- ================================================================ -->
        <!-- 左侧面板：分组列表 + 频道列表 + 节目单按钮（默认显示）          -->
        <!-- ================================================================ -->
        <!--
          ✅ 【2026-06-19 修改】改成四个角圆角 + 离左边有距离
          1. 新增 layout_marginStart="20dp"：离左边 20dp，让左侧圆角能看到
          2. 新增 layout_marginTop="20dp"：上边距 20dp
          3. 新增 layout_marginBottom="20dp"：下边距 20dp
          4. 新增 paddingTop/paddingBottom="20dp"：内容上下内边距
          5. 背景：panel_bg（四个角圆角，半透明深色）

          【和设置面板对称】
          - 频道面板：左边距 20dp，上下边距 20dp，四个角圆角
          - 设置面板：右边距 20dp，上下边距 20dp，四个角圆角
          完全对称！
        -->
        <LinearLayout
            android:id="@+id/ll_left_panel"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:background="@drawable/panel_bg"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- 分组列表 -->
            <ListView
                android:id="@+id/lv_group"
                android:layout_width="130dp"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:descendantFocusability="blocksDescendants"
                android:paddingStart="16dp"
                android:paddingEnd="8dp" />

            <!-- 频道列表 -->
            <ListView
                android:id="@+id/lv_channel_list"
                android:layout_width="200dp"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:descendantFocusability="blocksDescendants"
                android:paddingStart="8dp"
                android:paddingEnd="16dp" />

            <!-- 节目单按钮（在最右边） -->
            <TextView
                android:id="@+id/btn_show_epg"
                android:layout_width="50dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="节\n目\n单"
                android:textColor="#ffffff"
                android:textSize="14sp"
                android:focusable="true"
                android:clickable="true"
                android:paddingEnd="16dp" />

        </LinearLayout>

        <!-- ================================================================ -->
        <!-- 右侧面板：返回按钮 + 频道列表 + 日期列表 + EPG列表（默认隐藏）  -->
        <!-- ================================================================ -->
        <!--
          ✅ 【2026-06-19 修改】和左侧面板样式统一
          也是四个角圆角 + 离左边 20dp + 上下边距 20dp
          （因为右侧面板也在屏幕左边，和左侧面板切换显示）
        -->
        <LinearLayout
            android:id="@+id/ll_right_panel"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:background="@drawable/panel_bg"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            android:visibility="gone">

            <!-- 返回按钮（在最左边，显示"频道组"） -->
            <TextView
                android:id="@+id/btn_back_group"
                android:layout_width="50dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="频\n道\n组"
                android:textColor="#ffffff"
                android:textSize="14sp"
                android:focusable="true"
                android:clickable="true"
                android:paddingStart="16dp" />

            <!-- 频道列表（节目单页面的频道列表） -->
            <ListView
                android:id="@+id/lv_channel_list_epg"
                android:layout_width="200dp"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:descendantFocusability="blocksDescendants"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <!-- 日期列表 -->
            <ListView
                android:id="@+id/lv_date"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:descendantFocusability="blocksDescendants"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <!-- EPG节目列表 -->
            <ListView
                android:id="@+id/lv_epg"
                android:layout_width="360dp"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:descendantFocusability="blocksDescendants"
                android:paddingStart="8dp"
                android:paddingEnd="16dp" />

        </LinearLayout>

    </FrameLayout>

    <!-- ==================================================================== -->
    <!-- 底部信息栏（切台时显示，5 秒后自动隐藏）                            -->
    <!-- ==================================================================== -->
    <LinearLayout
        android:id="@+id/info_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:visibility="gone">

        <!-- 第一行：频道名 + 画质 + 音频 + 码率 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_channel_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_tag_fhd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:background="#DDDDDD"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:textSize="12sp"
                android:textColor="#000" />

            <TextView
                android:id="@+id/tv_tag_audio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="6dp"
                android:background="#DDDDDD"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:textSize="12sp"
                android:textColor="#000" />

            <TextView
                android:id="@+id/tv_bitrate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- 第二行：时间 + 进度条 + 剩余时间 + 节目名 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tv_current_time_range"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <ProgressBar
                android:id="@+id/progress_program"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="3dp"
                android:layout_marginHorizontal="8dp" />

            <TextView
                android:id="@+id/tv_remaining_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_current_program_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- 第三行：下一个节目 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tv_next_time_range"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_next_program_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
