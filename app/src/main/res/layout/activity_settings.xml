<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#B3000000">

        <!-- 投屏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="投屏播放"
                android:textColor="#ffffff"
                android:textSize="16sp"/>
            <TextView
                android:id="@+id/btn_cast"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="开始投屏"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:textColor="#ffffff"/>
        </LinearLayout>

        <!-- 开机自启 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="开机自启"
                android:textColor="#fff"
                android:textSize="16sp"/>
            <Switch
                android:id="@+id/sw_boot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- 节目单开关 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="节目单开关"
                android:textColor="#fff"
                android:textSize="16sp"/>
            <Switch
                android:id="@+id/sw_epg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- 自动更新源 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="自动更新源"
                android:textColor="#fff"
                android:textSize="16sp"/>
            <Switch
                android:id="@+id/sw_auto_update"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- 换台反转 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="换台反转"
                android:textColor="#fff"
                android:textSize="16sp"/>
            <Switch
                android:id="@+id/sw_reverse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- 数字选台 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="数字选台"
                android:textColor="#fff"
                android:textSize="16sp"/>
            <Switch
                android:id="@+id/sw_num_channel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- 屏幕比例 -->
        <TextView
            android:id="@+id/tv_screen_ratio"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:text="屏幕比例"
            android:textColor="#fff"
            android:textSize="16sp"/>

        <!-- 自定义订阅源 -->
        <TextView
            android:id="@+id/tv_custom_source"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:text="自定义订阅源"
            android:textColor="#fff"
            android:textSize="16sp"/>

        <!-- 自定义节目单 -->
        <TextView
            android:id="@+id/tv_custom_epg"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:text="自定义节目单"
            android:textColor="#fff"
            android:textSize="16sp"/>

        <!-- 多订阅源 -->
        <TextView
            android:id="@+id/tv_multi_source"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:text="多订阅源"
            android:textColor="#fff"
            android:textSize="16sp"/>

        <!-- 多节目单 -->
        <TextView
            android:id="@+id/tv_multi_epg"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:text="多节目单"
            android:textColor="#fff"
            android:textSize="16sp"/>

        <!-- 扫码添加直播源/节目单 -->
        <TextView
            android:id="@+id/tv_qr_code"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:text="扫码添加直播源/节目单"
            android:textColor="#fff"
            android:textSize="16sp"/>

        <!-- 检查更新 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="检查更新"
                android:textColor="#fff"
                android:textSize="16sp"/>
            <Button
                android:id="@+id/btn_check_update"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="检查更新"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>

        <!-- 播放器控制条 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="播放器控制条"
                android:textColor="#fff"
                android:textSize="16sp"/>
            <Button
                android:id="@+id/btn_toggle_controller"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="显示控制条"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>

        <!-- 网页提示 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:gravity="center"
            android:text="网页设置：http://设备IP:10481"
            android:textColor="#999"
            android:textSize="14sp"/>

    </LinearLayout>
</ScrollView>
