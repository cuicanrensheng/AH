<?xml version="1.0" encoding="utf-8"?>
<!--
  设置页面布局（右侧滑出式菜单风格）
  【作用】设置页面的整体布局
  【效果】屏幕右侧显示，四个角圆角，半透明深色背景
  【结构】FrameLayout（全屏透明） → 空白区域（点击关闭） + ScrollView（右侧内容）
  【2026-06-20 修改：添加点击空白区域关闭功能】
  新增 view_outside，点击左侧空白区域就关闭设置页面
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- ================================================================ -->
    <!-- ✅ 新增：左侧空白区域（点击关闭设置）                            -->
    <!-- ================================================================ -->
    <!--
      【作用】
      1. 占满左侧空间，让后面的播放界面能透过来
      2. 点击这个区域就关闭设置页面
      【为什么放在 ScrollView 前面？】
      FrameLayout 中后面的 View 盖在前面的上面。
      把 view_outside 放在前面，ScrollView 放在后面，
      这样点击面板区域不会触发关闭，只有点击左侧空白区域才会关闭。
    -->
    <View
        android:id="@+id/view_outside"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true" />

    <!-- ================================================================ -->
    <!-- 设置面板：靠右显示，离右边有 20dp 距离，四个角圆角半透明背景  -->
    <!-- ================================================================ -->
    <ScrollView
        android:id="@+id/settings_content"
        android:layout_width="240dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/settings_panel_bg"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- ... 里面的设置项保持不变 ... -->

    </ScrollView>

</FrameLayout>
