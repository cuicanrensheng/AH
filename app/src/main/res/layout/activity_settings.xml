<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00000000"
    android:fillViewport="true">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#B3000000">

        <!-- 开机自启 -->
        <LinearLayout
            android:id="@+id/item_boot"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/setting_item_bg"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="开机自启"
                android:textColor="@color/setting_item_text"
                android:textSize="16sp" />
            <Switch
                android:id="@+id/sw_boot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="false" />
        </LinearLayout>

        <!-- 节目单开关 -->
        <LinearLayout
            android:id="@+id/item_epg"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/setting_item_bg"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="节目单开关"
                android:textColor="@color/setting_item_text"
                android:textSize="16sp" />
            <Switch
                android:id="@+id/sw_epg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="false" />
        </LinearLayout>

        <!-- 自动更新源 -->
        <LinearLayout
            android:id="@+id/item_auto_update"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/setting_item_bg"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="自动更新源"
                android:textColor="@color/setting_item_text"
                android:textSize="16sp" />
            <Switch
                android:id="@+id/sw_auto_update"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="false" />
        </LinearLayout>

        <!-- 换台反转 -->
        <LinearLayout
            android:id="@+id/item_reverse"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/setting_item_bg"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="换台反转"
                android:textColor="@color/setting_item_text"
                android:textSize="16sp" />
            <Switch
                android:id="@+id/sw_reverse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="false" />
        </LinearLayout>

        <!-- 数字选台 -->
        <LinearLayout
            android:id="@+id/item_num_channel"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/setting_item_bg"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="数字选台"
                android:textColor="@color/setting_item_text"
                android:textSize="16sp" />
            <Switch
                android:id="@+id/sw_num_channel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="false" />
        </LinearLayout>

        <!-- 屏幕比例 -->
        <TextView
            android:id="@+id/tv_screen_ratio"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="屏幕比例"
            android:textColor="@color/setting_item_text"
            android:textSize="16sp"
            android:background="@drawable/setting_item_bg"
            android:focusable="true"
            android:clickable="true" />

        <!-- 自定义订阅源 -->
        <TextView
            android:id="@+id/tv_custom_source"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="自定义订阅源"
            android:textColor="@color/setting_item_text"
            android:textSize="16sp"
            android:background="@drawable/setting_item_bg"
            android:focusable="true"
            android:clickable="true" />

        <!-- 自定义节目单 -->
        <TextView
            android:id="@+id/tv_custom_epg"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="自定义节目单"
            android:textColor="@color/setting_item_text"
            android:textSize="16sp"
            android:background="@drawable/setting_item_bg"
            android:focusable="true"
            android:clickable="true" />

        <!-- 多订阅源 -->
        <TextView
            android:id="@+id/tv_multi_source"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="多订阅源"
            android:textColor="@color/setting_item_text"
            android:textSize="16sp"
            android:background="@drawable/setting_item_bg"
            android:focusable="true"
            android:clickable="true" />

        <!-- 多节目单 -->
        <TextView
            android:id="@+id/tv_multi_epg"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="多节目单"
            android:textColor="@color/setting_item_text"
            android:textSize="16sp"
            android:background="@drawable/setting_item_bg"
            android:focusable="true"
            android:clickable="true" />

        <!-- 扫码添加 -->
        <TextView
            android:id="@+id/tv_qr_code"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="扫码添加直播源/节目单"
            android:textColor="@color/setting_item_text"
            android:textSize="16sp"
            android:background="@drawable/setting_item_bg"
            android:focusable="true"
            android:clickable="true" />

        <!-- 查看解析日志 -->
        <TextView
            android:id="@+id/log_viewer"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="📄 查看解析日志"
            android:textColor="@color/setting_item_text"
            android:textSize="16sp"
            android:background="@drawable/setting_item_bg"
            android:focusable="true"
            android:clickable="true" />

        <!-- 操作崩溃日志 -->
        <TextView
            android:id="@+id/log_operation"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="📌 操作崩溃日志"
            android:textColor="@color/setting_item_text"
            android:textSize="16sp"
            android:background="@drawable/setting_item_bg"
            android:focusable="true"
            android:clickable="true" />

        <!-- 检查更新 -->
        <LinearLayout
            android:id="@+id/item_check_update"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/setting_item_bg"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="检查更新"
                android:textColor="@color/setting_item_text"
                android:textSize="16sp" />
            <Button
                android:id="@+id/btn_check_update"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="检查更新"
                android:focusable="false"
                android:clickable="false" />
        </LinearLayout>

        <!-- 网页设置提示 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="网页设置：http://设备IP:10481"
            android:textColor="#999"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
