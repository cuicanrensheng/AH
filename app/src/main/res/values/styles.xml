<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ================================================ -->
    <!-- 主主题：兼容模式（手机+电视都能用） -->
    <!-- ================================================ -->
    <!--
        【设计思路】
        1. 使用 shortEdges 模式（Android 9+ 支持，兼容性最好）
        2. 去掉可能导致电视崩溃的属性（windowTranslucentXxx）
        3. 保留基础的全屏属性
        4. Android 12+ 的手机会自动使用 values-v31 中的增强版
    -->
    <style name="Theme.TVLive.NoTitle" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <!-- 刘海屏适配：shortEdges 模式（Android 9+ 支持，兼容性最好） -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <!-- 内容延伸到系统栏后面 -->
        <item name="android:fitsSystemWindows">false</item>
        
        <!-- ✅ 2026-06-24 新增：窗口背景改成黑色，消除冷启动白屏 -->
        <!-- 【为什么要加这个？】 -->
        <!-- 应用冷启动时，系统会先显示一个"起始窗口"，这个窗口的背景色 -->
        <!-- 就是 windowBackground。改成黑色后，和播放器的黑色背景无缝衔接， -->
        <!-- 就看不到白屏了。电视性能差，启动慢，白屏会更明显，所以这个修改很有必要。 -->
        <item name="android:windowBackground">@android:color/black</item>
        
        <!--
            【注意】以下属性在某些电视上可能导致崩溃，暂时注释掉
            如果你的手机需要，可以在 values-v31 中单独开启
        -->
        <!-- <item name="android:statusBarColor">@android:color/transparent</item> -->
        <!-- <item name="android:navigationBarColor">@android:color/transparent</item> -->
        <!-- <item name="android:windowTranslucentStatus">true</item> -->
        <!-- <item name="android:windowTranslucentNavigation">true</item> -->
    </style>
    <!-- ================================================ -->
    <!-- SettingsActivity 透明主题（浮层效果） -->
    <!-- ================================================ -->
    <style name="TransparentTheme" parent="Theme.AppCompat.NoActionBar">
        <!-- 窗口是半透明的（关键） -->
        <item name="android:windowIsTranslucent">true</item>
        <!-- 窗口背景透明 -->
        <item name="android:windowBackground">@android:color/transparent</item>
        <!-- 没有标题栏 -->
        <item name="android:windowNoTitle">true</item>
        <!-- 全屏显示 -->
        <item name="android:windowFullscreen">true</item>
        <!-- 关闭背景变暗，否则会像遮罩一样盖住画面 -->
        <item name="android:backgroundDimEnabled">false</item>
        <!-- 暗度设为 0（完全透明） -->
        <item name="android:backgroundDimAmount">0</item>
        <!-- ✅ 新增：右侧滑入动画 -->
        <item name="android:windowAnimationStyle">@style/RightSlideAnimation</item>
        <!-- 去掉窗口内容覆盖 -->
        <item name="android:windowContentOverlay">@null</item>
        <!-- ✅ 新增：刘海屏适配（和主主题一致） -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <!-- ✅ 新增：内容延伸到系统栏后面（和主主题一致） -->
        <item name="android:fitsSystemWindows">false</item>
    </style>
    <!-- ================================================ -->
    <!-- ✅ 新增：右侧滑入动画样式 -->
    <!-- ================================================ -->
    <style name="RightSlideAnimation">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>
</resources>
